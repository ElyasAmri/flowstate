# Secrets and local environment -- never commit these
.env
.env.local
.env.*.local

# Maestro project config + local state (machine-local, not shared)
.maestro/

# Downloaded datasets (large; fetched from 4TU.ResearchData, not vendored).
# Ignore the contents but keep the catalog -- it declares what we have, no data.
datasets/*
!datasets/catalog.csv

# Obsidian local vault config (UI state, not shared)
docs/.obsidian/

# Node workspaces -- hoisted dependencies (root node_modules)
node_modules/

# E2E test sandbox (fresh flow library per run; never committed)
.local/

# Flow editor runtime library (written when the app runs against this dir)
.flowstate/
